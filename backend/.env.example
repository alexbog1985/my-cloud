# Django settings
SECRET_KEY=your-secret-key-here

# Debug mode
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database settings (PostgreSQL)
# Для разработки можно использовать SQLite (по умолчанию в settings.py)
# Для продакшена необходимо настроить PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mycloud
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Media files storage
MEDIA_ROOT=/absolute/path/to/my-cloud/backend/media

# CORS settings
# Для разработки можно оставить как есть
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production settings (опционально)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# Docker notes:
# - В режиме Docker DB_HOST=db (имя сервиса PostgreSQL)
# - В режиме разработки DB_HOST=localhost (локальный хост)
# - Секреты не должны попадать в репозиторий (.gitignore исключает .env)
